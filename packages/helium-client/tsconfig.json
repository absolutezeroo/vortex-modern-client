{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@core/*": ["../helium-engine/src/core/*"],
            "@core": ["../helium-engine/src/core"],
            "@habbo/*": ["../helium-engine/src/habbo/*"],
            "@habbo": ["../helium-engine/src/habbo"],
            "@room/*": ["../helium-engine/src/room/*"],
            "@room": ["../helium-engine/src/room"],
            "@iid/*": ["../helium-engine/src/iid/*"],
            "@iid": ["../helium-engine/src/iid"],
            "@ui/*": ["src/*"],
            "@/*": ["src/*"]
        },
        "outDir": "dist"
    },
    "include": ["src/**/*", "../helium-engine/src/**/*"]
}
